{
  "AllowedOrigins": [
    "https://fe-restaurant-qr.vercel.app"
  ],
  "ReverseProxy": {
    "Routes": {
      "identity-auth": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/v1/auth/{**catch-all}" }
      },
      "identity-account": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/v1/account/{**catch-all}" }
      },
      "menu-dishes": {
        "ClusterId": "menu",
        "Match": { "Path": "/api/v1/menu/{**catch-all}" }
      },
      "menu-snapshot": {
        "ClusterId": "menu",
        "Match": { "Path": "/api/v1/dish-snapshot/{**catch-all}" }
      },
      "menu-images": {
        "ClusterId": "menu",
        "Match": { "Path": "/images/{**catch-all}" }
      },
      "order-orders": {
        "ClusterId": "order",
        "Match": { "Path": "/api/v1/order/{**catch-all}" }
      },
      "order-tables": {
        "ClusterId": "order",
        "Match": { "Path": "/api/v1/table/{**catch-all}" }
      },
      "order-guests": {
        "ClusterId": "order",
        "Match": { "Path": "/api/v1/guest/{**catch-all}" }
      },
      "order-bills": {
        "ClusterId": "order",
        "Match": { "Path": "/api/v1/bill/{**catch-all}" }
      },
      "order-signalr": {
        "ClusterId": "order",
        "Match": { "Path": "/hubs/{**catch-all}" }
      },
      "reservation": {
        "ClusterId": "reservation",
        "Match": { "Path": "/api/v1/reservation/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity": { "Destinations": { "default": { "Address": "http://identity-api" } } },
      "menu": { "Destinations": { "default": { "Address": "http://menu-api" } } },
      "order": { "Destinations": { "default": { "Address": "http://order-api" } } },
      "reservation": { "Destinations": { "default": { "Address": "http://reservation-api" } } }
    }
  }
}